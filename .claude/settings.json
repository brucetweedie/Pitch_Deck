{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(node:*)",
      "Bash(npm run:*)",
      "Bash(ffmpeg:*)",
      "PowerShell(git add *)",
      "PowerShell(git commit *)",
      "PowerShell(git pull *)",
      "PowerShell(Copy-Item *)",
      "PowerShell(Move-Item *)",
      "PowerShell(New-Item *)",
      "PowerShell(Get-Content *)",
      "PowerShell(node *)",
      "PowerShell(npm run *)",
      "PowerShell(ffmpeg *)"
    ]
  }
}
